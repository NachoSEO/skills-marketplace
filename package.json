{
  "name": "skills-marketplace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "generate:skills": "tsx scripts/generate-skill-data.ts",
    "generate:all": "npm run generate:skills",
    "discover:skills": "tsx scripts/discover-skills.ts",
    "compute:rankings": "tsx scripts/compute-rankings.ts",
    "compute:similarities": "tsx scripts/compute-similarities.ts",
    "ingest": "npm run discover:skills && npm run generate:skills && npm run compute:rankings && npm run compute:similarities",
    "build:cloudflare": "npx opennextjs-cloudflare build",
    "preview": "npx opennextjs-cloudflare build && npx wrangler dev",
    "deploy": "npx opennextjs-cloudflare build && npx wrangler deploy"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "16.1.2",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@opennextjs/cloudflare": "^1.15.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.2",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "wrangler": "^4.60.0"
  }
}
